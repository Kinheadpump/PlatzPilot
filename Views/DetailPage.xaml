<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PlatzPilot.Models"
             xmlns:views="clr-namespace:PlatzPilot.Views"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="PlatzPilot.Views.DetailPage"
             x:DataType="views:DetailPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">

    <Grid RowDefinitions="Auto, *"
          BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
        
        <Grid Grid.Row="0" Padding="15,15,15,5">
            <Label Text="◀" FontSize="28" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" HorizontalOptions="Start">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding SortedSubSpaces}" 
                        SelectionMode="None" 
                        Margin="15,0,15,0"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
            
            <CollectionView.Header>
                <VerticalStackLayout Spacing="25" Margin="0,0,0,15">
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding LocationData.Name}" FontAttributes="Bold" FontSize="28" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label Text="{Binding LocationData.Subtitle}" FontSize="16" TextColor="Gray" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Button Grid.Column="0" Text="Auf Karte" 
                                Command="{Binding OpenMapCommand}" 
                                IsVisible="{Binding LocationData.HasLocation}" 
                                BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" CornerRadius="8" Padding="10"/>

                        <Button Grid.Column="1" Text="Website" 
                                Command="{Binding OpenUrlCommand}" 
                                CommandParameter="{Binding LocationData.MainUrl}"
                                BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" CornerRadius="8" Padding="10">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding LocationData.MainUrl}" Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Border BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#1e1e1e}" Padding="15" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="Gebäude:" FontAttributes="Bold" Margin="0,0,10,10"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding LocationData.BuildingDisplayText}" Margin="0,0,0,10" />
                            
                            <Label Grid.Row="1" Grid.Column="0" Text="Öffnungszeit:" FontAttributes="Bold" Margin="0,0,10,10"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding LocationData.TodayOpeningHours}" TextColor="{AppThemeBinding Light=#2c3e50, Dark=#bdc3c7}" Margin="0,0,0,10" />

                            <Label Grid.Row="2" Grid.Column="0" Text="Letzte Zählung:" FontAttributes="Bold" />
                            <Label Grid.Row="2" Grid.Column="1" Text="{Binding LocationData.LastUpdatedText}" TextColor="{AppThemeBinding Light=#2c3e50, Dark=#bdc3c7}" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=#f8f9fb, Dark=#1a1f28}"
                            Stroke="{AppThemeBinding Light=#d8dde6, Dark=#2e3540}"
                            StrokeThickness="1"
                            Padding="12"
                            StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding LocationData.PeakAverageText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2c3e50, Dark=#d5dbe5}" />
                            <Label Text="{Binding LocationData.SafetyLevelText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#4a5568, Dark=#aeb7c5}" />
                            <Label Text="{Binding LocationData.PeakTrendText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#4a5568, Dark=#aeb7c5}" />
                        </VerticalStackLayout>
                    </Border>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" />
                    <Label Text="Räume in diesem Gebäude" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:StudySpace">
                    <Border Margin="0,0,0,15" Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}" StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <Label Text="{Binding ClosedStatusText}"
                                       FontSize="12"
                                       TextColor="#e74c3c"
                                       IsVisible="False"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsOpen}" Value="False">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </HorizontalStackLayout>
                            
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8" Margin="0,2,0,0">
                                <Label Text="{Binding LevelDisplayText}" FontSize="12" TextColor="Gray" IsVisible="{Binding HasLevel}" />
                                <Label Text="{Binding RoomDisplayText}" FontSize="12" TextColor="Gray" IsVisible="{Binding HasRoom}" />
                            </HorizontalStackLayout>
                            <VerticalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Spacing="0" HorizontalOptions="End" VerticalOptions="Center">
                                <Label Text="{Binding AvailabilityText}"
                                       FontAttributes="Bold"
                                       FontSize="18"
                                       HorizontalOptions="End"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <Label Text="frei"
                                       FontSize="11"
                                       HorizontalOptions="End"
                                       TextColor="Gray" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
                                <Label Text="Auslastungsinformation"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#2c3e50, Dark=#d5dbe5}" />
                                <Grid ColumnDefinitions="*, Auto">
                                    <Label Text="Auslastung" FontSize="11" TextColor="Gray" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="Manuell gezählt" FontSize="9" TextColor="DarkOrange" IsVisible="{Binding IsManualCount}" VerticalOptions="Center" />
                                </Grid>
                                <ProgressBar Progress="{Binding OccupancyRate}" ProgressColor="{Binding OccupancyColor}" HeightRequest="6" Margin="0,5,0,0" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
