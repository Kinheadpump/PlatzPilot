<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:PlatzPilot.Models"
             xmlns:views="clr-namespace:PlatzPilot.Views"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:local="clr-namespace:PlatzPilot"
             xmlns:microcharts="clr-namespace:Microcharts.Maui;assembly=Microcharts.Maui"
             x:Class="PlatzPilot.Views.DetailPage"
             x:DataType="views:DetailPage"
             x:CompileBindings="True"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">

    <Grid RowDefinitions="Auto, *"
          BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
        
        <Grid Grid.Row="0" Padding="15,15,15,5">
            <Label Text="{x:Static local:AppText.BackGlyph}" FontSize="28" TextColor="{AppThemeBinding Light=Black, Dark=White}" VerticalOptions="Center" HorizontalOptions="Start">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <CollectionView Grid.Row="1" 
                        ItemsSource="{Binding SortedSubSpaces}" 
                        SelectionMode="None" 
                        Margin="15,0,15,0"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
            
            <CollectionView.Header>
                <VerticalStackLayout Spacing="25" Margin="0,0,0,15">
                    
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding LocationData.Name}" FontAttributes="Bold" FontSize="28" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                        <Label Text="{Binding LocationData.Subtitle}" FontSize="16" TextColor="Gray" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Button Grid.Column="0" Text="{x:Static local:AppText.OpenMapLabel}" 
                                Command="{Binding OpenMapCommand}" 
                                IsVisible="{Binding LocationData.HasLocation}" 
                                BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" CornerRadius="8" Padding="10"/>

                        <Button Grid.Column="1" Text="{x:Static local:AppText.OpenWebsiteLabel}" 
                                Command="{Binding OpenUrlCommand}" 
                                CommandParameter="{Binding LocationData.MainUrl}"
                                BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" 
                                TextColor="{AppThemeBinding Light=Black, Dark=White}" FontAttributes="Bold" CornerRadius="8" Padding="10">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding LocationData.MainUrl}" Value="{x:Null}">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Border BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#1e1e1e}" Padding="15" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0" Text="{x:Static local:AppText.BuildingLabel}" FontAttributes="Bold" Margin="0,0,10,10"/>
                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding LocationData.BuildingDisplayText}" Margin="0,0,0,10" />
                            
                            <Label Grid.Row="1" Grid.Column="0" Text="{x:Static local:AppText.OpeningHoursLabel}" FontAttributes="Bold" Margin="0,0,10,10"/>
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding LocationData.TodayOpeningHours}" TextColor="{AppThemeBinding Light=#2c3e50, Dark=#bdc3c7}" Margin="0,0,0,10" />

                            <Label Grid.Row="2"
                                   Grid.Column="0"
                                   Text="{x:Static local:AppText.LastCountLabel}"
                                   FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding LocationData.IsMensaVirtual}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding LocationData.LastUpdatedText}"
                                   TextColor="{AppThemeBinding Light=#2c3e50, Dark=#bdc3c7}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding LocationData.IsMensaVirtual}"
                                                 Value="True">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=#f8f9fb, Dark=#1a1f28}"
                            Stroke="{AppThemeBinding Light=#d8dde6, Dark=#2e3540}"
                            StrokeThickness="1"
                            Padding="12"
                            StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding LocationData.PeakAverageText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#2c3e50, Dark=#d5dbe5}" />
                            <Label Text="{Binding LocationData.SafetyLevelText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#4a5568, Dark=#aeb7c5}" />
                            <Label Text="{Binding LocationData.PeakTrendText}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#4a5568, Dark=#aeb7c5}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeThickness="1"
                            Padding="8"
                            StrokeShape="RoundRectangle 10"
                            IsVisible="{Binding HasChartData}">
                        <microcharts:ChartView Chart="{Binding OccupancyChart}"
                                               HeightRequest="{Binding ChartHeight}"
                                               BackgroundColor="Transparent" />
                    </Border>
                    <Grid ColumnDefinitions="*,*,*"
                          Margin="4,6,4,0"
                          IsVisible="{Binding HasChartData}">
                        <Label Grid.Column="0"
                               Text="{x:Static local:AppText.ChartLabel18Hours}"
                               FontSize="10"
                               Opacity="0.6"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                        <Label Grid.Column="1"
                               Text="{x:Static local:AppText.ChartLabel12Hours}"
                               FontSize="10"
                               Opacity="0.6"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                        <Label Grid.Column="2"
                               Text="{x:Static local:AppText.ChartLabel6Hours}"
                               FontSize="10"
                               Opacity="0.6"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray200}}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" />
                    <Label Text="{x:Static local:AppText.RoomsInBuildingLabel}" FontAttributes="Bold" FontSize="18" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:StudySpace"
                              x:CompileBindings="True">
                    <Border Margin="0,0,0,15" Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}" StrokeShape="RoundRectangle 10" StrokeThickness="1" Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="{Binding DisplayName}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding LevelDisplayText}" FontSize="12" TextColor="Gray" IsVisible="{Binding HasLevel}" />
                                    <Label Text="{Binding RoomDisplayText}" FontSize="12" TextColor="Gray" IsVisible="{Binding HasRoom}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Label Grid.Row="1"
                                   Grid.Column="0"
                                   Text="{Binding StatusText}"
                                   FontSize="12"
                                   TextColor="{Binding StatusTextColor}"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"
                                   IsVisible="{Binding HasStatusText}" />

                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.RowSpan="2"
                                                 Grid.Column="1"
                                                 Spacing="2"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Start">
                                <Label Text="{x:Static local:AppText.ManualCountLabel}"
                                       FontSize="10"
                                       TextColor="DarkOrange"
                                       IsVisible="{Binding IsManualCount}"
                                       HorizontalTextAlignment="End" />
                                <Label Text="{Binding AvailabilityDisplayText}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}"
                                       HorizontalTextAlignment="End"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <ProgressBar Grid.Row="2"
                                         Grid.ColumnSpan="2"
                                         Progress="{Binding TileOccupancyRate}"
                                         ProgressColor="{Binding TileOccupancyColor}"
                                         HeightRequest="6"
                                         Margin="0,8,0,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
