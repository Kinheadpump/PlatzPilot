                                       VerticalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">
                                    <Label Text="Statistische Prognosen"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                                    <Label Text="Wir berechnen auf Basis vergangener Daten, bis wann du spätestens ankommen solltest, um einen Platz zu bekommen."
                                           FontSize="13"
                                           LineHeight="1.3"
                                           TextColor="{AppThemeBinding Light=#3A3A3C, Dark=#D1D1D6}"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12"
                                  RowSpacing="4">
                                <Label Grid.Column="0"
                                       Text="⭐"
                                       FontSize="18"
                                       VerticalOptions="Start" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="2">
                                    <Label Text="Favoriten"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1C1C1E, Dark=White}" />
                                    <Label Text="Speichere deine Lieblings-Orte für den direkten Überblick beim App-Start."
                                           FontSize="13"
                                           LineHeight="1.3"
                                           TextColor="{AppThemeBinding Light=#3A3A3C, Dark=#D1D1D6}"
                                           LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F2F2F7, Dark=#2C2C2E}"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="10">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsDisclaimer], x:DataType=loc:LocalizationResourceManager}"
                                       FontSize="12"
                                       TextColor="#8E8E93"
                                       LineBreakMode="WordWrap" />
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Button Grid.Row="1"
                            Text="Verstanden &amp; Loslegen"
                            Command="{Binding CompleteOnboardingCommand}"
                            HeightRequest="50"
                            CornerRadius="12"
                            BackgroundColor="#1f6feb"
                            TextColor="White"
                            FontAttributes="Bold"
                            HorizontalOptions="Fill" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="99"
              Grid.ColumnSpan="99"
              HorizontalOptions="Fill"
              VerticalOptions="Fill"
              BackgroundColor="#A0000000"
              IsVisible="{Binding SeatList.IsBlockingOverlayVisible}"
              InputTransparent="False"
              ZIndex="99">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer />
            </Grid.GestureRecognizers>
            <ActivityIndicator IsRunning="{Binding SeatList.IsBlockingOverlayVisible}"
                               Color="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="60"
                               HeightRequest="60" />
        </Grid>

    </Grid>
</ContentPage>



