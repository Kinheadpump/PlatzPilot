                                    <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[OpeningHoursTitle], x:DataType=loc:LocalizationResourceManager}"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <Label Text="{Binding Filters.MinimumOpenHoursText}"
                                           FontSize="13"
                                           TextColor="Gray" />
