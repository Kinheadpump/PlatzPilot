<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PlatzPilot.ViewModels"
             xmlns:models="clr-namespace:PlatzPilot.Models"
             xmlns:local="clr-namespace:PlatzPilot"
             x:Class="PlatzPilot.Views.MainPage"
             x:DataType="viewmodels:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
    <Grid RowDefinitions="Auto, *, Auto"
          BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="15,15,15,8"
              IsVisible="{Binding IsMainContentVisible}">
            <Border Grid.Row="0"
                    IsVisible="{Binding IsOfflineBannerVisible}"
                    BackgroundColor="{AppThemeBinding Light=#fff4cc, Dark=#3a2f00}"
                    Stroke="{AppThemeBinding Light=#f0d48a, Dark=#4a3b00}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,6"
                    Margin="0,0,0,8">
                <Label Text="{x:Static local:AppText.OfflineBannerText}"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7a5a00, Dark=#f5d77a}"
                       HorizontalTextAlignment="Center" />
            </Border>

            <Border Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#ececec, Dark=#2a2a2a}"
                    StrokeThickness="1"
                    Padding="10,8"
                    StrokeShape="RoundRectangle 14">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0"
                           Text="{x:Static local:AppText.HomeTitle}"
                           FontSize="22"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           IsVisible="{Binding IsSearchInactive}" />

                    <SearchBar Grid.Column="0"
                               Placeholder="{x:Static local:AppText.SearchPlaceholder}"
                               Text="{Binding SearchText}"
                               IsVisible="{Binding IsSearchActive}"
                               BackgroundColor="Transparent" />

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#2a2a2a}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="44"
                            WidthRequest="44"
                            Padding="0"
                            VerticalOptions="Center">
                        <ImageButton Command="{Binding ToggleSearchCommand}"
                                     Source="{AppThemeBinding Light={x:Static local:AppAssets.SearchIconLight}, Dark={x:Static local:AppAssets.SearchIconDark}}"
                                     WidthRequest="44"
                                     HeightRequest="44"
                                     MinimumWidthRequest="44"
                                     MinimumHeightRequest="44"
                                     Padding="12"
                                     Aspect="AspectFit"
                                     BackgroundColor="Transparent"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#2a2a2a}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="44"
                            WidthRequest="44"
                            Padding="0"
                            VerticalOptions="Center">
                        <ImageButton Command="{Binding ToggleFilterCommand}"
                                     Source="{AppThemeBinding Light={x:Static local:AppAssets.FilterIconLight}, Dark={x:Static local:AppAssets.FilterIconDark}}"
                                     WidthRequest="44"
                                     HeightRequest="44"
                                     MinimumWidthRequest="44"
                                     MinimumHeightRequest="44"
                                     Padding="12"
                                     Aspect="AspectFit"
                                     BackgroundColor="Transparent"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     Command="{Binding LoadSpacesCommand}"
                     IsVisible="{Binding IsMainContentVisible}"
                     BackgroundColor="Transparent">
            <Grid>
                <CollectionView ItemsSource="{Binding UiLocations}"
                                SelectionMode="None"
                                BackgroundColor="Transparent"
                                Margin="10,0,10,10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:UiLocation">
                            <Border Margin="0,5,0,5"
                                    Padding="15"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="1">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainPageViewModel}}, Path=GoToDetailCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      ColumnSpacing="14"
                                      RowSpacing="12">
                                    <VerticalStackLayout Grid.Row="0"
                                                         Grid.Column="0"
                                                         Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="16"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Subtitle}"
                                               FontSize="12"
                                               TextColor="Gray"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding BestArrivalText}"
                                               FontSize="11"
                                               TextColor="{AppThemeBinding Light=#53627c, Dark=#9ca9bc}"
                                               IsVisible="{Binding ShowBestArrivalInTile}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding ClosedStatusText}"
                                               FontSize="11"
                                               TextColor="#e74c3c"
                                               IsVisible="False"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"
                                               Margin="{Binding ClosedLabelMargin}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsOpen}"
                                                             Value="False">
                                                    <Setter Property="IsVisible"
                                                            Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Grid Grid.Row="0"
                                          Grid.Column="1"
                                          RowDefinitions="Auto,Auto,Auto"
                                          RowSpacing="0"
                                          HorizontalOptions="End"
                                          VerticalOptions="Start"
                                          MinimumWidthRequest="72">
                                        <ImageButton Grid.Row="0"
                                                     Source="{x:Static local:AppAssets.FavoriteIconOutline}"
                                                     WidthRequest="20"
                                                     HeightRequest="20"
                                                     MinimumWidthRequest="24"
                                                     MinimumHeightRequest="24"
                                                     Padding="2"
                                                     Aspect="AspectFit"
                                                     HorizontalOptions="End"
                                                     VerticalOptions="Start"
                                                     BackgroundColor="Transparent"
                                                     Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainPageViewModel}}, Path=ToggleFavoriteCommand}"
                                                     CommandParameter="{Binding .}">
                                            <ImageButton.Triggers>
                                                <DataTrigger TargetType="ImageButton"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="True">
                                                    <Setter Property="Source"
                                                            Value="{x:Static local:AppAssets.FavoriteIconFilled}" />
                                                    <Setter Property="Opacity"
                                                            Value="1" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="ImageButton"
                                                             Binding="{Binding IsFavorite}"
                                                             Value="False">
                                                    <Setter Property="Source"
                                                            Value="{x:Static local:AppAssets.FavoriteIconOutline}" />
                                                    <Setter Property="Opacity"
                                                            Value="1" />
                                                </DataTrigger>
                                            </ImageButton.Triggers>
                                        </ImageButton>

                                        <Label Grid.Row="1"
                                               Text="{Binding HomeAvailabilityText}"
                                               FontAttributes="Bold"
                                               FontSize="20"
                                               Margin="0,2,0,0"
                                               HorizontalOptions="End"
                                               HorizontalTextAlignment="End"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsOpen}"
                                                             Value="False">
                                                    <Setter Property="FontSize"
                                                            Value="12" />
                                                    <Setter Property="TextColor"
                                                            Value="Gray" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsOpen}"
                                                             Value="True">
                                                    <Setter Property="FontSize"
                                                            Value="20" />
                                                    <Setter Property="TextColor"
                                                            Value="{AppThemeBinding Light=Black, Dark=White}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label Grid.Row="2"
                                               Text="{Binding HomeAvailabilitySubText}"
                                               FontSize="11"
                                               HorizontalOptions="End"
                                               HorizontalTextAlignment="End"
                                               TextColor="Gray"
                                               IsVisible="{Binding IsHomeAvailabilitySubVisible}" />
                                    </Grid>

                                    <VerticalStackLayout Grid.Row="1"
                                                         Grid.ColumnSpan="2">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="{x:Static local:AppText.OccupancyLabel}"
                                                   FontSize="12"
                                                   TextColor="Gray"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Column="1"
                                                   Text="{x:Static local:AppText.ManualCountLabel}"
                                                   FontSize="10"
                                                   TextColor="DarkOrange"
                                                   IsVisible="{Binding IsManualCount}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                        <ProgressBar Progress="{Binding HomeOccupancyRate}"
                                                     ProgressColor="{Binding HomeOccupancyColor}"
                                                     HeightRequest="6"
                                                     Margin="0,5,0,0" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12"
                                     IsVisible="{Binding IsHomeEmpty}">
                    <Label Text="{Binding EmptyStateTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding EmptyStateSubtitle}"
                           FontSize="14"
                           TextColor="Gray"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"
                           IsVisible="{Binding IsEmptySubtitleVisible}" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="{AppThemeBinding Light=#1f6feb, Dark=#9ec1ff}"
                                       WidthRequest="32"
                                       HeightRequest="32" />
                </VerticalStackLayout>

                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     IsVisible="{Binding IsFavoritesEmpty}">
                    <Label Text="{x:Static local:AppText.FavoritesEmptyText}"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Grid>
        </RefreshView>

        <ScrollView Grid.Row="0"
                    Grid.RowSpan="2"
                    IsVisible="{Binding IsSettingsContentVisible}"
                    Margin="15,30,15,15">
            <VerticalStackLayout Spacing="25">
                <Label Text="{x:Static local:AppText.SettingsTitle}"
                       FontAttributes="Bold"
                       FontSize="28"
                       Margin="0,10,0,10" />

                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                    <Label Grid.Row="0"
                           Text="{x:Static local:AppText.SettingsDisplayTitle}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}" />

                    <Border Grid.Row="1"
                            Padding="14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{x:Static local:AppText.SettingsDesignLabel}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <ImageButton Grid.Column="1"
                                             Source="{AppThemeBinding Light={x:Static local:AppAssets.DarkModeIconLight}, Dark={x:Static local:AppAssets.DarkModeIconDark}}"
                                             Command="{Binding ToggleThemeCommand}"
                                             BackgroundColor="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             Padding="8" />
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{x:Static local:AppText.ColorBlindModeLabel}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <ImageButton Grid.Column="1"
                                             Command="{Binding ToggleColorBlindModeCommand}"
                                             BackgroundColor="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             Padding="8">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsColorBlindMode}"
                                                     Value="True">
                                            <Setter Property="Source"
                                                    Value="{AppThemeBinding Light={x:Static local:AppAssets.ColorBlindOnIconLight}, Dark={x:Static local:AppAssets.ColorBlindOnIconDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsColorBlindMode}"
                                                     Value="False">
                                            <Setter Property="Source"
                                                    Value="{AppThemeBinding Light={x:Static local:AppAssets.ColorBlindOffIconLight}, Dark={x:Static local:AppAssets.ColorBlindOffIconDark}}" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{x:Static local:AppText.CampusSouthOnlyLabel}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <ImageButton Grid.Column="1"
                                             Command="{Binding ToggleCampusSouthOnlyCommand}"
                                             BackgroundColor="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             Padding="8">
                                    <ImageButton.Triggers>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsCampusSouthOnly}"
                                                     Value="True">
                                            <Setter Property="Source"
                                                    Value="{AppThemeBinding Light={x:Static local:AppAssets.CampusSouthOnIconLight}, Dark={x:Static local:AppAssets.CampusSouthOnIconDark}}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="ImageButton"
                                                     Binding="{Binding IsCampusSouthOnly}"
                                                     Value="False">
                                            <Setter Property="Source"
                                                    Value="{AppThemeBinding Light={x:Static local:AppAssets.CampusSouthOffIconLight}, Dark={x:Static local:AppAssets.CampusSouthOffIconDark}}" />
                                        </DataTrigger>
                                    </ImageButton.Triggers>
                                </ImageButton>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                    <Label Grid.Row="0"
                           Text="{x:Static local:AppText.SettingsFeedbackTitle}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}" />

                    <Border Grid.Row="1"
                            Padding="14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="{x:Static local:AppText.SettingsHapticLabel}"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold" />

                            <ImageButton Grid.Column="1"
                                         Command="{Binding ToggleHapticFeedbackCommand}"
                                         BackgroundColor="Transparent"
                                         HeightRequest="40"
                                         WidthRequest="40"
                                         Padding="8">
                                <ImageButton.Triggers>
                                    <DataTrigger TargetType="ImageButton"
                                                 Binding="{Binding IsHapticFeedbackEnabled}"
                                                 Value="True">
                                        <Setter Property="Source"
                                                Value="{AppThemeBinding Light={x:Static local:AppAssets.CampusSouthOnIconLight}, Dark={x:Static local:AppAssets.CampusSouthOnIconDark}}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="ImageButton"
                                                 Binding="{Binding IsHapticFeedbackEnabled}"
                                                 Value="False">
                                        <Setter Property="Source"
                                                Value="{AppThemeBinding Light={x:Static local:AppAssets.CampusSouthOffIconLight}, Dark={x:Static local:AppAssets.CampusSouthOffIconDark}}" />
                                    </DataTrigger>
                                </ImageButton.Triggers>
                            </ImageButton>
                        </Grid>
                    </Border>
                </Grid>

                <Border Padding="15"
                        Margin="0,50,0,0"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0">
                    <VerticalStackLayout Spacing="8"
                                         HorizontalOptions="Center">
                        <Image Source="{x:Static local:AppAssets.SettingsLogo}"
                               HeightRequest="60"
                               WidthRequest="60"
                               Margin="0,0,0,10"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding SettingsVersionText}"
                               FontSize="12"
                               TextColor="Gray"
                               HorizontalOptions="Center" />
                        <Label Text="{x:Static local:AppText.SettingsDisclaimer}"
                               Margin="0,8,0,0"
                               FontSize="11"
                               TextColor="Gray"
                               HorizontalTextAlignment="Center" />
                        <Grid Margin="0,10,0,0"
                              ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="6"
                              HorizontalOptions="Fill">
                            <Button Grid.Column="0"
                                    Text="{x:Static local:AppText.GithubLabel}"
                                    Command="{Binding OpenGithubCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Padding="6,8" />
                            <Button Grid.Column="1"
                                    Text="{x:Static local:AppText.ImpressumLabel}"
                                    Command="{Binding ShowImpressumCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Padding="6,8" />
                            <Button Grid.Column="2"
                                    Text="{x:Static local:AppText.PrivacyLabel}"
                                    Command="{Binding ShowPrivacyCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Padding="6,8" />
                            <Button Grid.Column="3"
                                    Text="{x:Static local:AppText.LicensesLabel}"
                                    Command="{Binding ShowLicensesCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    CornerRadius="8"
                                    HeightRequest="40"
                                    Padding="6,8" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#151515}"
                StrokeThickness="0"
                Padding="0,5,0,25">
            <Border.Shadow>
                <Shadow Brush="Black"
                        Opacity="0.1"
                        Offset="0,-3"
                        Radius="10" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">
                <VerticalStackLayout Grid.Column="0"
                                     HorizontalOptions="Fill"
                                     BackgroundColor="Transparent"
                                     Padding="0,10"
                                     Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}"
                                              CommandParameter="{x:Static local:AppTabs.Home}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light={x:Static local:AppAssets.HomeIconLight}, Dark={x:Static local:AppAssets.HomeIconDark}}"
                           HeightRequest="24"
                           WidthRequest="24"
                           HorizontalOptions="Center" />
                    <Label Text="{x:Static local:AppText.HomeTabLabel}"
                           FontSize="10"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Home}">
                            <Setter Property="Opacity"
                                    Value="1.0" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Favorites}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Settings}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Fill"
                                     BackgroundColor="Transparent"
                                     Padding="0,10"
                                     Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}"
                                              CommandParameter="{x:Static local:AppTabs.Favorites}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light={x:Static local:AppAssets.FavoritesIconLight}, Dark={x:Static local:AppAssets.FavoritesIconDark}}"
                           HeightRequest="24"
                           WidthRequest="24"
                           HorizontalOptions="Center" />
                    <Label Text="{x:Static local:AppText.FavoritesLabel}"
                           FontSize="10"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Favorites}">
                            <Setter Property="Opacity"
                                    Value="1.0" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Home}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Settings}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     HorizontalOptions="Fill"
                                     BackgroundColor="Transparent"
                                     Padding="0,10"
                                     Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}"
                                              CommandParameter="{x:Static local:AppTabs.Settings}" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light={x:Static local:AppAssets.SettingsIconLight}, Dark={x:Static local:AppAssets.SettingsIconDark}}"
                           HeightRequest="24"
                           WidthRequest="24"
                           HorizontalOptions="Center" />
                    <Label Text="{x:Static local:AppText.SettingsLabel}"
                           FontSize="10"
                           HorizontalOptions="Center"
                           FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Settings}">
                            <Setter Property="Opacity"
                                    Value="1.0" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Home}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout"
                                     Binding="{Binding CurrentTab}"
                                     Value="{x:Static local:AppTabs.Favorites}">
                            <Setter Property="Opacity"
                                    Value="0.3" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Grid.RowSpan="2"
              IsVisible="{Binding IsFilterExpanded}"
              ZIndex="20">
            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#1A000000, Dark=#33000000}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseFilterSheetCommand}" />
                </Border.GestureRecognizers>
            </Border>

            <Border VerticalOptions="End"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#151515}"
                    StrokeShape="RoundRectangle 22,22,0,0"
                    HeightRequest="640">
                <Grid RowDefinitions="Auto,*,Auto">
                    <Grid Grid.Row="0"
                          Padding="20,12,20,8"
                          ColumnDefinitions="*">
                        <VerticalStackLayout Spacing="6">
                            <BoxView WidthRequest="46"
                                     HeightRequest="5"
                                     HorizontalOptions="Center"
                                     Color="{AppThemeBinding Light=#d7d7d7, Dark=#3b3b3b}"
                                     CornerRadius="4" />
                            <Label Text="{x:Static local:AppText.FilterTitle}"
                                   FontSize="22"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                        <Button Text="{x:Static local:AppText.FilterReset}"
                                Command="{Binding ResetFiltersCommand}"
                                BackgroundColor="{AppThemeBinding Light=#e9f0ff, Dark=#24324d}"
                                TextColor="{AppThemeBinding Light=#1f4db8, Dark=#9ec1ff}"
                                CornerRadius="8"
                                FontSize="14"
                                Padding="8,0"
                                HeightRequest="36"
                                HorizontalOptions="End"
                                VerticalOptions="Center" />
                    </Grid>

                    <ScrollView x:Name="FilterSheetScroll"
                                Grid.Row="1">
                        <VerticalStackLayout Padding="20,0,20,20"
                                             Spacing="18">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{x:Static local:AppText.SortTitle}"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <Label Text="{x:Static local:AppText.SortByLabel}"
                                               VerticalOptions="Center" />
                                        <Picker Grid.Column="1"
                                                ItemsSource="{Binding SortOptions}"
                                                SelectedItem="{Binding SelectedSortOption}" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="{x:Static local:AppText.WhenTitle}"
                                           FontAttributes="Bold"
                                           FontSize="16" />

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="{x:Static local:AppText.WhenNow}"
                                                Command="{Binding SetWhenNowCommand}"
                                                CornerRadius="10"
                                                Padding="10,8">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding UseNow}"
                                                             Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#1f6feb" />
                                                    <Setter Property="TextColor"
                                                            Value="White" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding UseNow}"
                                                             Value="False">
                                                    <Setter Property="BackgroundColor"
                                                            Value="{AppThemeBinding Light=White, Dark=#2a2a2a}" />
                                                    <Setter Property="TextColor"
                                                            Value="{AppThemeBinding Light=Black, Dark=White}" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                        <Button Grid.Column="1"
                                                Text="{x:Static local:AppText.WhenBefore}"
                                                Command="{Binding SetWhenBeforeCommand}"
                                                CornerRadius="10"
                                                Padding="10,8">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding UseNow}"
                                                             Value="False">
                                                    <Setter Property="BackgroundColor"
                                                            Value="#1f6feb" />
                                                    <Setter Property="TextColor"
                                                            Value="White" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Button"
                                                             Binding="{Binding UseNow}"
                                                             Value="True">
                                                    <Setter Property="BackgroundColor"
                                                            Value="{AppThemeBinding Light=White, Dark=#2a2a2a}" />
                                                    <Setter Property="TextColor"
                                                            Value="{AppThemeBinding Light=Black, Dark=White}" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </Grid>

                                    <Border x:Name="PastTimeFilterPanel"
                                            IsVisible="{Binding IsBeforeMode}"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=White, Dark=#202020}"
                                            Padding="12"
                                            StrokeShape="RoundRectangle 10">
                                        <Grid ColumnDefinitions="*,*"
                                              ColumnSpacing="10">
                                            <DatePicker Grid.Column="0"
                                                        Date="{Binding SelectedDate}"
                                                        MaximumDate="{Binding MaxSelectableDate}"
                                                        Format="{x:Static local:AppFormats.DatePicker}" />
                                            <TimePicker Grid.Column="1"
                                                        Time="{Binding SelectedTime}"
                                                        Format="{x:Static local:AppFormats.TimePicker}" />
                                        </Grid>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{x:Static local:AppText.RoomTypeTitle}"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding IsGroupRoomSelected}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.RoomTypeGroup}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding IsSilentStudySelected}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.RoomTypeSilent}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding IsNoReservationSelected}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.RoomTypeNoReservation}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{x:Static local:AppText.EquipmentTitle}"
                                           FontAttributes="Bold"
                                           FontSize="16" />

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding RequireFreeWifi}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.EquipmentWifi}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding RequirePowerOutlets}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.EquipmentPower}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding RequireWhiteboard}" />
                                        <Label Grid.Column="1"
                                               Text="{x:Static local:AppText.EquipmentWhiteboard}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="{x:Static local:AppText.OpeningHoursTitle}"
                                           FontAttributes="Bold"
                                           FontSize="16" />
                                    <Label Text="{Binding MinimumOpenHoursText}"
                                           FontSize="13"
                                           TextColor="Gray" />
                                    <Slider Minimum="{Binding MinimumOpenHoursMin}"
                                            Maximum="{Binding MinimumOpenHoursMax}"
                                            x:Name="OpeningHoursSlider"
                                            ValueChanged="OnOpeningHoursSliderValueChanged"
                                            Value="{Binding MinimumOpenHours}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Border Grid.Row="2"
                            StrokeThickness="0"
                            Padding="16,10,16,16"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#151515}">
                        <Button Text="{Binding ShowResultsButtonText}"
                                Command="{Binding ApplySheetFiltersCommand}"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="52"
                                CornerRadius="14"
                                BackgroundColor="#1f6feb"
                                TextColor="White" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="0"
              Grid.RowSpan="3"
              IsVisible="{Binding IsBusy}"
              BackgroundColor="{AppThemeBinding Light=#66FFFFFF, Dark=#66000000}"
              ZIndex="30">
            <ActivityIndicator IsRunning="True"
                               Color="{AppThemeBinding Light=#1f6feb, Dark=#9ec1ff}"
                               WidthRequest="40"
                               HeightRequest="40"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>
