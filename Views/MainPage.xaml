<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PlatzPilot.ViewModels"
             xmlns:models="clr-namespace:PlatzPilot.Models"
             x:Class="PlatzPilot.Views.MainPage"
             x:DataType="viewmodels:MainPageViewModel"
             Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="Auto, Auto, *, Auto">
        
        <Border Grid.Row="0"
                IsVisible="{Binding IsMainContentVisible}"
                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                Stroke="{AppThemeBinding Light=#ececec, Dark=#2a2a2a}"
                StrokeThickness="1"
                Margin="15,15,15,5"
                Padding="10,8"
                StrokeShape="RoundRectangle 14">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" VerticalOptions="Center">
                <Button Grid.Column="0"
                        Text="Jetzt"
                        Command="{Binding SetNowCommand}"
                        BackgroundColor="{Binding NowButtonColor}"
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="30"
                        Padding="12,0"
                        FontSize="13"
                        FontAttributes="Bold"/>

                <HorizontalStackLayout Grid.Column="1"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Spacing="8">
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#262626}"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,5">
                        <DatePicker Date="{Binding SelectedDate}"
                                    Format="dd.MM.yyyy"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#2C3E50, Dark=#ECF0F1}"
                                    FontAttributes="Bold"/>
                    </Border>

                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#262626}"
                            StrokeShape="RoundRectangle 10"
                            Padding="10,5">
                        <TimePicker Time="{Binding SelectedTime}"
                                    Format="HH:mm"
                                    FontSize="13"
                                    TextColor="{AppThemeBinding Light=#2C3E50, Dark=#ECF0F1}"
                                    FontAttributes="Bold"/>
                    </Border>
                </HorizontalStackLayout>

                <Border Grid.Column="2"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#2a2a2a}"
                        StrokeShape="RoundRectangle 9"
                        HeightRequest="32"
                        WidthRequest="32"
                        Padding="6"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                    <ImageButton Command="{Binding ToggleFilterCommand}"
                                 Source="{AppThemeBinding Light=icon_filter.png, Dark=icon_filter_white.png}"
                                 WidthRequest="16"
                                 HeightRequest="16"
                                 Padding="0"
                                 Aspect="AspectFit"
                                 BackgroundColor="Transparent"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                IsVisible="{Binding IsFilterExpanded}"
                BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#1e1e1e}"
                StrokeThickness="0" Margin="0,10,0,10" Padding="15">
            <VerticalStackLayout Spacing="15">
                <SearchBar Placeholder="Nach Bib oder Kürzel suchen..." Text="{Binding SearchText}" BackgroundColor="Transparent" />
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="Sortieren nach:" VerticalOptions="Center" FontAttributes="Bold" />
                    <Picker Grid.Column="1" Margin="10,0,0,0" ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SelectedSortOption}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

            <RefreshView Grid.Row="2" IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}" Command="{Binding LoadSpacesCommand}" IsVisible="{Binding IsMainContentVisible}">            <Grid>
                <CollectionView ItemsSource="{Binding UiLocations}" SelectionMode="None" Margin="10,0,10,10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:UiLocation">
                            <Border Margin="0,5,0,5" 
                                    Padding="15" 
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}" 
                                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}" 
                                    StrokeShape="RoundRectangle 10" 
                                    StrokeThickness="1">
                                
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainPageViewModel}}, Path=GoToDetailCommand}" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <HorizontalStackLayout Grid.Row="0" Spacing="6">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" />
                                        <Label Text="Geschlossen"
                                               FontSize="12"
                                               TextColor="#e74c3c"
                                               IsVisible="False"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsOpen}" Value="False">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </HorizontalStackLayout>
                                    <Label Grid.Row="1" Text="{Binding Subtitle}" FontSize="12" TextColor="Gray" />
                                    <HorizontalStackLayout Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" VerticalOptions="Center" Spacing="10">
                                        <Label Text="{Binding FavoriteIcon}" TextColor="{Binding FavoriteColor}" FontSize="28" VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainPageViewModel}}, Path=ToggleFavoriteCommand}" CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                        <VerticalStackLayout Spacing="0" HorizontalOptions="End" VerticalOptions="Center">
                                            <Label Text="{Binding AvailabilityText}"
                                                   FontAttributes="Bold"
                                                   FontSize="18"
                                                   HorizontalOptions="End"
                                                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                                            <Label Text="frei"
                                                   FontSize="11"
                                                   HorizontalOptions="End"
                                                   TextColor="Gray" />
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                    <VerticalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Margin="0,15,0,0">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Text="Auslastung" FontSize="12" TextColor="Gray" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="Manuell gezählt" FontSize="10" TextColor="DarkOrange" IsVisible="{Binding IsManualCount}" VerticalOptions="Center" />
                                        </Grid>
                                        <ProgressBar Progress="{Binding OccupancyRate}" ProgressColor="{Binding OccupancyColor}" HeightRequest="6" Margin="0,5,0,0" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" IsVisible="{Binding IsListEmpty}">
                    <Label Text="Nichts zu finden 🕵️" FontSize="18" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </RefreshView>

        <ScrollView Grid.Row="0" Grid.RowSpan="3" IsVisible="{Binding IsSettingsContentVisible}" Margin="15,30,15,15">
            <VerticalStackLayout Spacing="25">
                <Label Text="Einstellungen" FontAttributes="Bold" FontSize="28" Margin="0,10,0,10" />

                <Border Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Design (Hell / Dunkel)" VerticalOptions="Center" FontAttributes="Bold" />
                        
                        <ImageButton Grid.Column="1" 
                                     Source="{AppThemeBinding Light=icon_dark_mode.png, Dark=icon_dark_mode_white.png}" 
                                     Command="{Binding ToggleThemeCommand}" 
                                     BackgroundColor="Transparent"
                                     HeightRequest="40" WidthRequest="40" 
                                     Padding="8" />
                    </Grid>
                </Border>
                
                <Border Padding="15" BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Image Source="logo_ui.png" HeightRequest="60" WidthRequest="60" Margin="0,0,0,10" HorizontalOptions="Center"/>
                        <Label Text="Version 1.0.0" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="3" BackgroundColor="{AppThemeBinding Light=White, Dark=#151515}" StrokeThickness="0" Padding="0,5,0,25">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Offset="0,-3" Radius="10" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*">
                
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Fill" BackgroundColor="Transparent" Padding="0,10" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Home" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light=icon_home.png, Dark=icon_home_white.png}" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                    <Label Text="Home" FontSize="10" HorizontalOptions="Center" FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Home"><Setter Property="Opacity" Value="1.0" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Favorites"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Settings"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Fill" BackgroundColor="Transparent" Padding="0,10" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Favorites" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light=icon_favorite.png, Dark=icon_favorite_white.png}" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                    <Label Text="Favoriten" FontSize="10" HorizontalOptions="Center" FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Favorites"><Setter Property="Opacity" Value="1.0" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Home"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Settings"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Fill" BackgroundColor="Transparent" Padding="0,10" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="Settings" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Image Source="{AppThemeBinding Light=icon_settings.png, Dark=icon_settings_white.png}" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" />
                    <Label Text="Einstellungen" FontSize="10" HorizontalOptions="Center" FontAttributes="Bold" />
                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Settings"><Setter Property="Opacity" Value="1.0" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Home"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding CurrentTab}" Value="Favorites"><Setter Property="Opacity" Value="0.3" /></DataTrigger>
                    </VerticalStackLayout.Triggers>
                </VerticalStackLayout>

            </Grid>
        </Border>

    </Grid>
</ContentPage>
