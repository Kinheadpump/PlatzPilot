                                            ValueChanged="OnOpeningHoursSliderValueChanged"
                                            Value="{Binding Filters.MinimumOpenHours}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>

                    <Border Grid.Row="2"
                            StrokeThickness="0"
                            Padding="16,10,16,16"
