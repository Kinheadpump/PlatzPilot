<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PlatzPilot.ViewModels"
             xmlns:models="clr-namespace:PlatzPilot.Models"
             xmlns:constants="clr-namespace:PlatzPilot.Constants"
             xmlns:loc="clr-namespace:PlatzPilot.Localization"
             xmlns:views="clr-namespace:PlatzPilot.Views"
             xmlns:behaviors="clr-namespace:PlatzPilot.Behaviors"
             x:Class="PlatzPilot.Views.MainPage"
             x:DataType="viewmodels:MainPageViewModel"
             x:CompileBindings="True"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
    <Grid RowDefinitions="Auto, *, Auto"
          BackgroundColor="{AppThemeBinding Light=White, Dark=#1f1f1f}">
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              Margin="15,15,15,8"
              IsVisible="{Binding Navigation.IsMainContentVisible}">
            <Border Grid.Row="0"
                    IsVisible="{Binding SeatList.IsOfflineBannerVisible}"
                    BackgroundColor="{AppThemeBinding Light=#fff4cc, Dark=#3a2f00}"
                    Stroke="{AppThemeBinding Light=#f0d48a, Dark=#4a3b00}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="10,6"
                    Margin="0,0,0,8">
                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[OfflineBannerText], x:DataType=loc:LocalizationResourceManager}"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#7a5a00, Dark=#f5d77a}"
                       HorizontalTextAlignment="Center" />
            </Border>

            <Border Grid.Row="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                    Stroke="{AppThemeBinding Light=#ececec, Dark=#2a2a2a}"
                    StrokeThickness="1"
                    Padding="10,8"
                    StrokeShape="RoundRectangle 14">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="8"
                      VerticalOptions="Center">
                    <Label Grid.Column="0"
                           Text="{Binding SelectedCity.DisplayName}"
                           FontAttributes="Bold"
                           FontSize="24"
                           HorizontalOptions="Start"
                           TextColor="{AppThemeBinding Light=#6b7280, Dark=#cbd5e1}"
                           VerticalOptions="Center"
                           IsVisible="{Binding Filters.IsSearchInactive}" />

                    <SearchBar Grid.Column="0"
                               Placeholder="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SearchPlaceholder], x:DataType=loc:LocalizationResourceManager}"
                               Text="{Binding Filters.SearchText}"
                               IsVisible="{Binding Filters.IsSearchActive}"
                               BackgroundColor="Transparent" />

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#2a2a2a}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="44"
                            WidthRequest="44"
                            Padding="0"
                            VerticalOptions="Center">
                        <ImageButton Command="{Binding Filters.ToggleSearchCommand}"
                                     Source="{AppThemeBinding Light={x:Static constants:AppAssets.SearchIconLight}, Dark={x:Static constants:AppAssets.SearchIconDark}}"
                                     WidthRequest="44"
                                     HeightRequest="44"
                                     MinimumWidthRequest="44"
                                     MinimumHeightRequest="44"
                                     Padding="12"
                                     Aspect="AspectFit"
                                     BackgroundColor="Transparent"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center" />
                    </Border>

                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#f1f2f6, Dark=#2a2a2a}"
                            StrokeShape="RoundRectangle 12"
                            HeightRequest="44"
                            WidthRequest="44"
                            Padding="0"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Filters.ToggleFilterCommand}" />
                        </Border.GestureRecognizers>
                        <Image Source="{AppThemeBinding Light={x:Static constants:AppAssets.FilterIconLight}, Dark={x:Static constants:AppAssets.FilterIconDark}}"
                               WidthRequest="24"
                               HeightRequest="24"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Image.Triggers>
                                <DataTrigger TargetType="Image"
                                             Binding="{Binding Filters.IsFilterActive}"
                                             Value="True">
                                    <Setter Property="Source"
                                            Value="{x:Static constants:AppAssets.FilterIconActive}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Image"
                                             Binding="{Binding Filters.IsFilterActive}"
                                             Value="False">
                                    <Setter Property="Source"
                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.FilterIconLight}, Dark={x:Static constants:AppAssets.FilterIconDark}}" />
                                </DataTrigger>
                            </Image.Triggers>
                        </Image>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding SeatList.IsRefreshing, Mode=TwoWay}"
                     Command="{Binding SeatList.LoadSpacesCommand}"
                     IsVisible="{Binding Navigation.IsMainContentVisible}"
                     BackgroundColor="Transparent">
            <Grid>
                <CollectionView ItemsSource="{Binding SeatList.UiLocations}"
                                SelectionMode="Single"
                                SelectedItem="{Binding SeatList.SelectedLocation, Mode=TwoWay}"
                                BackgroundColor="Transparent"
                                Margin="10,0,10,10">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:UiLocation"
                                      x:CompileBindings="True">
                            <Border Margin="0,5,0,5"
                                    Padding="15"
                                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="1">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsSkeleton}"
                                                 Value="True">
                                        <Setter Property="MinimumHeightRequest" Value="150" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsSkeleton}"
                                                 Value="False">
                                        <Setter Property="MinimumHeightRequest" Value="0" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Grid>
                                    <Grid x:Name="ContentGrid"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid"
                                                         Binding="{Binding IsSkeleton}"
                                                         Value="True">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Grid.Triggers>
                                        <Grid Grid.Column="0"
                                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                              RowSpacing="6">
                                            <VerticalStackLayout Grid.Row="0"
                                                                 Spacing="2">
                                                <Label Text="{Binding TileName}"
                                                       FontAttributes="Bold"
                                                       FontSize="16"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding Subtitle}"
                                                       FontSize="12"
                                                       TextColor="Gray"
                                                       MaxLines="1"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>

                                            <Label Grid.Row="1"
                                                   Text="{Binding BestArrivalText}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#7b8aa6, Dark=#c4d0e1}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation" />

                                            <Label Grid.Row="2"
                                                   Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   TextColor="{Binding StatusTextColor}"
                                                   MaxLines="2"
                                                   LineBreakMode="TailTruncation"
                                                   IsVisible="{Binding HasStatusText}" />

                                            <Grid Grid.Row="3"
                                                  ColumnDefinitions="*,Auto">
                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="2"
                                                                     HorizontalOptions="End">
                                                    <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[ManualCountLabel], x:DataType=loc:LocalizationResourceManager}"
                                                           FontSize="10"
                                                           TextColor="DarkOrange"
                                                           IsVisible="{Binding IsManualCountVisible}"
                                                           HorizontalTextAlignment="End" />
                                                    <Label Text="{Binding HomeAvailabilityText}"
                                                           FontAttributes="Bold"
                                                           FontSize="15"
                                                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}"
                                                           HorizontalTextAlignment="End"
                                                           MaxLines="1"
                                                           LineBreakMode="TailTruncation" />
                                                </VerticalStackLayout>
                                            </Grid>

                                            <ProgressBar Grid.Row="4"
                                                         Progress="{Binding HomeOccupancyRate}"
                                                         ProgressColor="{Binding HomeOccupancyColor}"
                                                         HeightRequest="6"
                                                         Margin="0,4,0,0" />
                                        </Grid>

                                        <Grid Grid.Column="1"
                                              RowDefinitions="Auto,*,Auto"
                                              RowSpacing="0"
                                              VerticalOptions="Fill"
                                              HorizontalOptions="End">
                                            <ImageButton Grid.Row="0"
                                                         Source="{x:Static constants:AppAssets.FavoriteIconOutline}"
                                                         WidthRequest="24"
                                                         HeightRequest="24"
                                                         MinimumWidthRequest="28"
                                                         MinimumHeightRequest="28"
                                                         Padding="3"
                                                         Aspect="AspectFit"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Start"
                                                         BackgroundColor="Transparent"
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type views:MainPage}}, Path=ViewModel.SeatList.ToggleFavoriteCommand, x:DataType=views:MainPage}"
                                                         CommandParameter="{Binding .}">
                                                <ImageButton.Triggers>
                                                    <DataTrigger TargetType="ImageButton"
                                                                 Binding="{Binding IsFavorite}"
                                                                 Value="True">
                                                        <Setter Property="Source"
                                                                Value="{x:Static constants:AppAssets.FavoriteIconFilled}" />
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="ImageButton"
                                                                 Binding="{Binding IsFavorite}"
                                                                 Value="False">
                                                        <Setter Property="Source"
                                                                Value="{x:Static constants:AppAssets.FavoriteIconOutline}" />
                                                        <Setter Property="Opacity"
                                                                Value="1" />
                                                    </DataTrigger>
                                                </ImageButton.Triggers>
                                            </ImageButton>

                                            <Label Grid.Row="1"
                                                   Text="›"
                                                   FontSize="20"
                                                   TextColor="{AppThemeBinding Light=#9aa0a6, Dark=#8b939f}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Grid>

                                    <Grid x:Name="SkeletonGrid"
                                          IsVisible="False"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Fill">
                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid"
                                                         Binding="{Binding IsSkeleton}"
                                                         Value="True">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Grid.Triggers>
                                        <Grid.Behaviors>
                                            <behaviors:ShimmerBehavior />
                                        </Grid.Behaviors>
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <Grid Grid.Column="0"
                                                  RowDefinitions="Auto,*,Auto"
                                                  RowSpacing="8"
                                                  HorizontalOptions="Fill">
                                                <Border HeightRequest="18"
                                                        Grid.Row="0"
                                                        Margin="0,0,120,0"
                                                        BackgroundColor="{AppThemeBinding Light=#e3e6ea, Dark=#2a2f35}"
                                                        StrokeShape="RoundRectangle 10" />
                                                <Border HeightRequest="6"
                                                        Grid.Row="2"
                                                        Margin="0,6,0,0"
                                                        BackgroundColor="{AppThemeBinding Light=#e3e6ea, Dark=#2a2f35}"
                                                        StrokeShape="RoundRectangle 6" />
                                            </Grid>
                                            <Border Grid.Column="1"
                                                    HeightRequest="20"
                                                    WidthRequest="20"
                                                    Margin="0,2,0,0"
                                                    BackgroundColor="{AppThemeBinding Light=#e3e6ea, Dark=#2a2f35}"
                                                    StrokeShape="RoundRectangle 8"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="12"
                                     IsVisible="{Binding SeatList.IsNoResultsEmpty}">
                    <Label Text="{Binding SeatList.EmptyStateTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center" />
                    <Label Text="{Binding SeatList.EmptyStateSubtitle}"
                           FontSize="14"
                           TextColor="Gray"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap"
                           IsVisible="{Binding SeatList.IsEmptySubtitleVisible}" />
                </VerticalStackLayout>

                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     IsVisible="{Binding SeatList.IsFavoritesEmpty}">
                    <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[FavoritesEmptyText], x:DataType=loc:LocalizationResourceManager}"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           HorizontalOptions="Center"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Grid>
        </RefreshView>

        <ScrollView Grid.Row="0"
                    Grid.RowSpan="2"
                    IsVisible="{Binding Navigation.IsSettingsContentVisible}"
                    Margin="15,30,15,15">
            <VerticalStackLayout Spacing="25">
                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsTitle], x:DataType=loc:LocalizationResourceManager}"
                       FontAttributes="Bold"
                       FontSize="28"
                       Margin="0,10,0,10" />

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      RowSpacing="10">
                    <Label Grid.Row="0"
                           Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsDisplayTitle], x:DataType=loc:LocalizationResourceManager}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}" />

                    <Border Grid.Row="1"
                            Padding="14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsDesignLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <ImageButton Grid.Column="1"
                                             Source="{AppThemeBinding Light={x:Static constants:AppAssets.DarkModeIconLight}, Dark={x:Static constants:AppAssets.DarkModeIconDark}}"
                                             Command="{Binding Settings.ToggleThemeCommand}"
                                             BackgroundColor="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             Padding="8" />
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[LanguageLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <ImageButton Grid.Column="1"
                                             Source="{AppThemeBinding Light={x:Static constants:AppAssets.LanguageIconLight}, Dark={x:Static constants:AppAssets.LanguageIconDark}}"
                                             Command="{Binding Settings.ChangeLanguageCommand}"
                                             BackgroundColor="Transparent"
                                             HeightRequest="40"
                                             WidthRequest="40"
                                             Padding="8" />
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[ColorBlindModeLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="8">
                                    <Grid>
                                        <Image HeightRequest="24"
                                               WidthRequest="24"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsColorBlindMode}"
                                                             Value="True">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.ColorBlindOnIconLight}, Dark={x:Static constants:AppAssets.ColorBlindOnIconDark}}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsColorBlindMode}"
                                                             Value="False">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.ColorBlindOffIconLight}, Dark={x:Static constants:AppAssets.ColorBlindOffIconDark}}" />
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Settings.ToggleColorBlindModeCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <Label Grid.Row="2"
                           Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsFeedbackTitle], x:DataType=loc:LocalizationResourceManager}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}" />

                    <Border Grid.Row="3"
                            Padding="14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[CityLabel], x:DataType=loc:LocalizationResourceManager}"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold" />

                            <Picker Title="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[CitySelectTitle], x:DataType=loc:LocalizationResourceManager}"
                                    ItemsSource="{Binding Settings.AvailableCities}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding Settings.SelectedCity}"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Center"
                                    FontAttributes="Bold" />

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto"
                                  IsEnabled="{Binding Settings.IsKarlsruheSelected}"
                                  Opacity="{Binding Settings.CampusSouthOpacity}">
                                <Label Text="{Binding Settings.CampusSouthLabel}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="8">
                                    <Grid>
                                        <Image HeightRequest="24"
                                               WidthRequest="24"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsCampusSouthOnly}"
                                                             Value="True">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOnIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOnIconDark}}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsCampusSouthOnly}"
                                                             Value="False">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOffIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOffIconDark}}" />
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Settings.ToggleCampusSouthOnlyCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsHapticLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="8">
                                    <Grid>
                                        <Image HeightRequest="24"
                                               WidthRequest="24"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsHapticFeedbackEnabled}"
                                                             Value="True">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOnIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOnIconDark}}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsHapticFeedbackEnabled}"
                                                             Value="False">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOffIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOffIconDark}}" />
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Settings.ToggleHapticFeedbackCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[HideClosedLocationsLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="8">
                                    <Grid>
                                        <Image HeightRequest="24"
                                               WidthRequest="24"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsHideClosedLocations}"
                                                             Value="True">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOnIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOnIconDark}}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Image"
                                                             Binding="{Binding Settings.IsHideClosedLocations}"
                                                             Value="False">
                                                    <Setter Property="Source"
                                                            Value="{AppThemeBinding Light={x:Static constants:AppAssets.CampusSouthOffIconLight}, Dark={x:Static constants:AppAssets.CampusSouthOffIconDark}}" />
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Settings.ToggleHideClosedLocationsCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </Grid>

                            <BoxView HeightRequest="1"
                                     Color="{AppThemeBinding Light=#ededed, Dark=#2a2a2a}" />

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsCrashReportLabel], x:DataType=loc:LocalizationResourceManager}"
                                       VerticalOptions="Center"
                                       FontAttributes="Bold" />

                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        HeightRequest="40"
                                        WidthRequest="40"
                                        Padding="8">
                                    <Grid>
                                        <Image HeightRequest="24"
                                               WidthRequest="24"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               InputTransparent="True"
                                               Source="{Binding Settings.CrashReportIcon}" />
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Settings.ToggleCrashReportCommand}" />
                                        </Grid.GestureRecognizers>
                                    </Grid>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Label Grid.Row="4"
                           Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[SettingsInfoTitle], x:DataType=loc:LocalizationResourceManager}"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4a4a4a, Dark=#cfcfcf}" />

                    <Border Grid.Row="5"
                            Padding="14"
                            BackgroundColor="{AppThemeBinding Light=White, Dark=#1e1e1e}"
                            Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333333}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto"
