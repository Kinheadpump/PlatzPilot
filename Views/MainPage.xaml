                                               Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[EquipmentWifi], x:DataType=loc:LocalizationResourceManager}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding Filters.RequirePowerOutlets}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[EquipmentPower], x:DataType=loc:LocalizationResourceManager}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding Filters.RequireWhiteboard}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[EquipmentWhiteboard], x:DataType=loc:LocalizationResourceManager}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#f7f8fa, Dark=#1f1f1f}"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">
