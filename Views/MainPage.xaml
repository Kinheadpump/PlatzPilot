                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding Filters.IsSilentStudySelected}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[RoomTypeSilent], x:DataType=loc:LocalizationResourceManager}"
                                               VerticalOptions="Center" />
