                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="10">
                                        <CheckBox IsChecked="{Binding Filters.IsNoReservationSelected}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[RoomTypeNoReservation], x:DataType=loc:LocalizationResourceManager}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

