                                Command="{Binding SeatList.ApplySheetFiltersCommand}"
                                FontAttributes="Bold"
                                FontSize="16"
                                HeightRequest="52"
                                CornerRadius="14"
                                BackgroundColor="#1f6feb"
                                TextColor="White" />
