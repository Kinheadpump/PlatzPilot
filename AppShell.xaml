<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PlatzPilot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PlatzPilot"
    xmlns:views="clr-namespace:PlatzPilot.Views"
    Title="{x:Static local:AppInfoValues.Name}">

    <ShellContent Title="{x:Static local:AppText.HomeTabLabel}"
                  ContentTemplate="{DataTemplate views:MainPage}"
                  Route="{x:Static local:AppRoutes.MainPage}" />

</Shell>
