<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PlatzPilot.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:constants="clr-namespace:PlatzPilot.Constants"
    xmlns:loc="clr-namespace:PlatzPilot.Localization"
    xmlns:views="clr-namespace:PlatzPilot.Views"
    Title="{x:Static constants:AppInfoValues.Name}">

    <ShellContent Title="{Binding Source={x:Static loc:LocalizationResourceManager.Instance}, Path=[HomeTabLabel], x:DataType=loc:LocalizationResourceManager}"
                  ContentTemplate="{DataTemplate views:MainPage}"
                  Route="{x:Static constants:AppRoutes.MainPage}" />

</Shell>

